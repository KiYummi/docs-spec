{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ips.local/schemas/api_contract_schema.json",
  "title": "IPS API Contract",
  "description": "Validates API contract definition files for the IPS project.",
  "type": "object",
  "required": ["module", "module_id", "layer", "source", "endpoints"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema URI reference."
    },
    "module": {
      "type": "string",
      "description": "Module name, e.g. {模块B}."
    },
    "module_id": {
      "type": "string",
      "pattern": "^[A-Z]{2,4}[-]?[0-9]{0,2}(,[A-Z]{2,4}[-]?[0-9]{0,2})*$",
      "description": "Module ID such as {数据模块2}, {平台模块2}, {集成模块1}, MKT, TRX."
    },
    "layer": {
      "type": "string",
      "enum": ["DATA", "COL", "INT", "{应用层}"],
      "description": "Architecture layer the module belongs to."
    },
    "source": {
      "type": "string",
      "description": "Source document reference, e.g. 01b_Arch-Platform.md §{平台模块2}."
    },
    "endpoints": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["method", "path", "summary", "responses"],
        "additionalProperties": false,
        "properties": {
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"],
            "description": "HTTP method."
          },
          "path": {
            "type": "string",
            "description": "URL path, e.g. /api/v1/auth/login."
          },
          "summary": {
            "type": "string",
            "description": "Brief description of the endpoint."
          },
          "permission_code": {
            "type": "string",
            "description": "RBAC permission code, format: {module}:{resource}:{action}."
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Grouping tags for the endpoint."
          },
          "auth_required": {
            "type": "boolean",
            "default": true,
            "description": "Whether authentication is required."
          },
          "rate_limit_level": {
            "type": "string",
            "description": "Rate limit tier, e.g. L1_public, L2_authenticated, L3_tenant."
          },
          "request_body": {
            "type": "object",
            "required": ["content_type", "fields"],
            "additionalProperties": false,
            "properties": {
              "content_type": {
                "type": "string",
                "description": "MIME type of the request body, e.g. application/json."
              },
              "fields": {
                "type": "array",
                "items": {
                  "$ref": "#/definitions/fieldDefinition"
                },
                "description": "Fields in the request body."
              }
            }
          },
          "query_params": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/fieldDefinition"
            },
            "description": "Query string parameters."
          },
          "path_params": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/fieldDefinition"
            },
            "description": "Path parameters extracted from the URL."
          },
          "responses": {
            "type": "object",
            "patternProperties": {
              "^[1-5][0-9]{2}$": {
                "type": "object",
                "required": ["description"],
                "additionalProperties": true,
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "schema": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            },
            "additionalProperties": false,
            "description": "Response definitions keyed by HTTP status code."
          },
          "idempotency": {
            "type": "string",
            "enum": ["none", "token", "key"],
            "default": "none",
            "description": "Idempotency strategy: none, client token, or business key."
          },
          "error_codes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Error codes this endpoint may return."
          },
          "business_rules": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Business rules enforced by this endpoint."
          },
          "events_published": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Domain events published by this endpoint."
          },
          "edge_cases": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "case": {
                  "type": "string",
                  "description": "Edge case scenario description."
                },
                "handling": {
                  "type": "string",
                  "description": "How this edge case is handled."
                }
              }
            },
            "description": "Edge cases and special handling for this endpoint."
          },
          "notes": {
            "type": "string",
            "description": "Additional implementation notes or caveats."
          }
        }
      }
    }
  },
  "definitions": {
    "fieldDefinition": {
      "type": "object",
      "required": ["name", "type", "description"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "description": "Field name."
        },
        "type": {
          "type": "string",
          "description": "Field data type."
        },
        "required": {
          "type": "boolean",
          "default": false,
          "description": "Whether the field is required."
        },
        "description": {
          "type": "string",
          "description": "Field description."
        }
      }
    }
  }
}
